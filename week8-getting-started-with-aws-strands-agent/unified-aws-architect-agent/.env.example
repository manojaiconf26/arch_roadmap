# Groq API Key (Required for Groq models)
GROQ_API_KEY=your_groq_api_key_here

# AWS Credentials (Required for Bedrock)
# Configure via AWS CLI or set here
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_SESSION_TOKEN=your_aws_token (if using temporary credentials)
AWS_REGION=us-east-1

# Bedrock Model ID (Optional - defaults to Claude Sonnet 4.5)
# MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0

# Model Provider (defaults to groq)
# Options: groq, bedrock
PROVIDER=groq
